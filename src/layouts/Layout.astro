---
import '@/styles/global.css'
import '@/styles/typography.css'

import Footer from '@/components/Footer.astro'
import Head from '@/components/Head.astro'
import Navbar from '@/components/react/navbar'
import { SITE } from '@/consts'
import { cn } from '@/lib/utils'
import ClientRouter from 'astro/components/ClientRouter.astro';
import { fade } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import headerGradient from '@/assets/header-gradient.svg';
import footerGradient from '@/assets/footer-gradient.svg';

const {
  isWide = false
} = Astro.props
---

<!doctype html>
<html lang={SITE.locale}>
  <Head>
    <slot name="head" />
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="+FHMgRP7/Duxaq5D0gZtJw" async></script>

    <!-- Preload critical resources -->
   <link rel="preload" href="/fonts/ClashDisplay/ClashDisplay-Semibold.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Epilogue/Epilogue-Regular.ttf" as="font" type="truetype" crossorigin />

    <!-- DNS prefetch for external resources -->
    <link rel="dns-prefetch" href="//analytics.ahrefs.com" />

    <script is:inline transition:persist>
  (function() {
    function applyTheme() {
      try {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored === 'dark' || (!stored && prefersDark);

        document.documentElement.classList.toggle('dark', isDark);
      } catch (e) {
        console.warn('Theme apply failed', e);
      }
    }

    // Apply immediately on load
    applyTheme();

    // Only apply BEFORE swap to prevent double application
    document.addEventListener('astro:before-swap', (e) => {
      // Apply theme to the new document before it swaps
      const stored = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = stored === 'dark' || (!stored && prefersDark);

      // Apply to the incoming document
      e.newDocument.documentElement.classList.toggle('dark', isDark);
    });

    // System theme changes
    const media = window.matchMedia('(prefers-color-scheme: dark)');
    media.addEventListener('change', (e) => {
      if (!localStorage.getItem('theme')) {
        document.documentElement.classList.toggle('dark', e.matches);
      }
    });
  })();
</script>
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />
    <Analytics />
    <ClientRouter />

    <script is:inline transition:persist>
    (function() {
      function initScrollReveal() {
        var els = document.querySelectorAll('[data-scroll]');
        if (!els.length) return;

        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              var el = entry.target;
              var delay = el.getAttribute('data-scroll-delay');
              if (delay) {
                setTimeout(function() { el.classList.add('is-visible'); }, parseInt(delay));
              } else {
                el.classList.add('is-visible');
              }
              observer.unobserve(el);
            }
          });
        }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

        els.forEach(function(el) {
          if (el.classList.contains('is-visible')) return;
          observer.observe(el);
        });
      }

      // On initial load
      initScrollReveal();

      // Before swap: mark all data-scroll elements in the new page as visible
      // so they don't flash as invisible during the DOM swap
      document.addEventListener('astro:before-swap', function(e) {
        var scrollEls = e.newDocument.querySelectorAll('[data-scroll]');
        scrollEls.forEach(function(el) {
          el.classList.add('is-visible');
        });
      });

      // After page load: reset elements not in viewport so they animate on scroll
      document.addEventListener('astro:page-load', function() {
        var els = document.querySelectorAll('[data-scroll].is-visible');
        els.forEach(function(el) {
          var rect = el.getBoundingClientRect();
          var inViewport = rect.top < window.innerHeight && rect.bottom > 0;
          if (!inViewport) {
            el.classList.remove('is-visible');
          }
        });
        initScrollReveal();
      });
    })();
    </script>
  </Head>
  <body>
    <div class="flex h-fit min-h-screen w-full flex-col gap-y-4 sm:gap-y-6 font-sans relative">

      <Navbar client:load transition:persist />
      <main transition:animate={fade({ duration: '0.15s' })} class="flex grow flex-col bg-background mt-16 lg:mt-6 relative z-10" aria-label="Main content" role="main">
        <div class="absolute top-0 left-0 right-0 mx-auto w-full h-[100px]  bg-[linear-gradient(to_right,#a855f7,#6366f1,#22d3ee)] blur-3xl opacity-60 -z-50"></div>
        <div
          class={cn(
            'mx-auto flex grow flex-col gap-y-4 sm:gap-y-6 px-3 py-10 sm:py-16 md:py-20 lg:py-24 sm:px-6 lg:px-8 relative',
            !isWide && 'max-w-5xl'
          )}
        >
          <slot />
        </div>
      </main>
      <Footer />
    </div>
  </body>
</html>
